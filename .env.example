# X API credentials (Free tier)
# Get these from https://developer.x.com/en/portal/dashboard
# Under your App → Keys and Tokens → OAuth 1.0 Keys

# Consumer Key (aka API Key / App Key)
X_APP_KEY=
# Consumer Secret (aka API Secret / App Secret)
X_APP_SECRET=

# Access Token + Secret — click "Generate" under OAuth 1.0 Keys
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
